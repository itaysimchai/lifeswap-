rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userData(id) { return get(/databases/$(database)/documents/users/$(id)).data; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(uid()))
        && userData(uid()).role == 'admin';
    }
    function notBlocked() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(uid()))
        && userData(uid()).get('isBlocked', false) != true;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && uid() == userId
        && request.resource.data.role == 'user'
        && request.resource.data.isProvider == false
        && request.resource.data.providerStatus == 'none'
        && request.resource.data.isBlocked == false;
      allow update: if isAdmin() || (
        signedIn() && uid() == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.isProvider == resource.data.isProvider
        && request.resource.data.providerStatus == resource.data.providerStatus
        && request.resource.data.isBlocked == resource.data.isBlocked
      );
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if signedIn();
      allow create: if signedIn() && notBlocked()
        && request.resource.data.providerId == uid()
        && userData(uid()).isProvider == true
        && request.resource.data.status in ['active', 'paused'];
      allow update: if signedIn() && notBlocked()
        && resource.data.providerId == uid()
        && request.resource.data.providerId == resource.data.providerId;
      allow delete: if signedIn() && notBlocked()
        && resource.data.providerId == uid();
    }

    match /serviceRequests/{requestId} {
      allow read: if signedIn()
        && (isAdmin() || resource.data.requesterId == uid() || resource.data.providerId == uid());
      allow create, update, delete: if false;
    }

    match /chats/{chatId} {
      function chatParticipants() {
        return get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      }
      allow read: if signedIn() && uid() in resource.data.participantIds;
      allow create: if false;
      allow update: if signedIn() && notBlocked()
        && uid() in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if signedIn() && uid() in chatParticipants();
        allow create: if signedIn() && notBlocked()
          && uid() in chatParticipants()
          && request.resource.data.senderId == uid();
      }
    }

    match /bookedSlots/{slotId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /mail/{mailId} {
      allow read, create, update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read, create, update, delete: if false;
    }

    match /slotLocks/{slotLockId} {
      allow read, create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if signedIn() && notBlocked()
        && request.resource.data.reporterId == uid()
        && request.resource.data.status == 'open';
      allow update, delete: if isAdmin();
    }

    match /applications/{userId} {
      allow read: if isAdmin() || (signedIn() && uid() == userId);
      allow create: if signedIn() && notBlocked() && uid() == userId
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }
  }
}
