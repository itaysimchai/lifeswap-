# ─── Firebase ─────────────────────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com, add a Web App, and copy
# its config below. These NEXT_PUBLIC_ values are safe to expose (not secrets).
# Enable Email/Password (and Google, optional) under Authentication > Sign-in method.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set "true" to use the local Firebase Emulator Suite (npm run emulators) instead
# of a live project. Leave "false" in production (Netlify).
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe (cards) ───────────────────────────────────────────────────────────
# From the Stripe Dashboard → Developers → API keys (use TEST keys to start).
# The publishable key is NEXT_PUBLIC_ (safe in the browser); the others are
# server-only secrets. The app falls back to demo checkout if these are unset.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From `stripe listen` (local) or the Dashboard webhook (prod). Only needed for
# the webhook backup — the success page works without it.
STRIPE_WEBHOOK_SECRET=

# ─── Firebase Admin (server) — PRODUCTION ONLY ────────────────────────────────
# Not needed for local testing with the emulator. For production, download a
# service-account JSON (Firebase console → Project settings → Service accounts →
# Generate new private key) and paste its 3 fields here. Never commit these.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
