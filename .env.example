# Firebase web app config. These NEXT_PUBLIC_ values are safe to expose.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set true only when using the Firebase Emulator Suite locally.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Public app URL. In production this must be your Netlify URL/custom domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin SDK. Required in production server routes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# PayPal. Use sandbox first; switch PAYPAL_ENV to live only with live credentials.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_WEBHOOK_ID=

# Email delivery through Resend.
RESEND_API_KEY=
EMAIL_FROM="LifeSwap <onboarding@resend.dev>"

# Long random string. Required only for internal server-to-server email route use.
INTERNAL_API_SECRET=
